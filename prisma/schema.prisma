generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id @default(cuid())
  clerkId          String       @unique
  role             Role         @default(STUDENT)
  firstName        String
  lastName         String
  email            String       @unique
  timezone         String       @default("UTC")
  qualifications   String?
  subjects         String[]
  stripeAccountId  String?
  // Student profile fields
  age              Int?
  gender           String?
  fathersName      String?
  mothersName      String?
  createdAt        DateTime     @default(now())
  courses          Course[]     @relation("InstructorCourses")
  enrollments      Enrollment[]
}

model Course {
  id                  String       @id @default(cuid())
  instructorId        String
  instructor          User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  title               String
  description         String
  subject             Subject
  courseType          CourseType   @default(LIVE)
  durationWeeks       Int          @default(0)
  daysOfWeek          String[]
  startTimeUtc        String       @default("")
  sessionDurationMins Int          @default(0)
  feeUsd              Decimal      @db.Decimal(10, 2)
  contentUrl          String?
  status              CourseStatus @default(PENDING)
  zoomMeetingId       String?
  zoomJoinUrl         String?
  zoomStartUrl        String?
  createdAt           DateTime     @default(now())
  enrollments         Enrollment[]
}

model Enrollment {
  id                    String   @id @default(cuid())
  studentId             String
  student               User     @relation(fields: [studentId], references: [id])
  courseId              String
  course                Course   @relation(fields: [courseId], references: [id])
  stripePaymentIntentId String?
  amountPaidUsd         Decimal  @db.Decimal(10, 2)
  instructorPayoutUsd   Decimal  @db.Decimal(10, 2)
  platformFeeUsd        Decimal  @db.Decimal(10, 2)
  zoomJoinUrl           String?
  enrolledAt            DateTime @default(now())
  instructorPaidOut     Boolean  @default(false)
  instructorPaidOutAt   DateTime?
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum Subject {
  BIOLOGY
  PHYSICAL_SCIENCE
  CHEMISTRY
  MATHEMATICS
}

enum CourseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CourseType {
  LIVE
  SELF_PACED
}
