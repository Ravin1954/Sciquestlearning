generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id @default(cuid())
  clerkId          String       @unique
  role             Role         @default(STUDENT)
  firstName        String
  lastName         String
  email            String       @unique
  timezone         String       @default("UTC")
  country          String       @default("")
  qualifications   String?
  subjects         String[]
  stripeAccountId  String?
  bankInfo         String?
  // Student profile fields
  age              Int?
  gender           String?
  fathersName      String?
  mothersName      String?
  createdAt        DateTime     @default(now())
  courses          Course[]     @relation("InstructorCourses")
  enrollments      Enrollment[]
}

model Course {
  id                  String       @id @default(cuid())
  instructorId        String
  instructor          User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  title               String
  description         String
  subject             Subject
  courseType          CourseType   @default(LIVE)
  durationWeeks       Int          @default(0)
  durationUnit        String       @default("WEEKS")
  daysOfWeek          String[]
  startTimeUtc        String       @default("")
  sessionDurationMins Int          @default(0)
  feeUsd              Decimal      @db.Decimal(10, 2)
  contentUrl          String?
  gradeLevel          String       @default("")
  topics              String[]     @default([])
  scheduleJson        String       @default("")
  status              CourseStatus @default(PENDING)
  rejectionRemark     String?
  zoomMeetingId       String?
  zoomJoinUrl         String?
  zoomStartUrl        String?
  createdAt           DateTime     @default(now())
  enrollments         Enrollment[]
}

model Enrollment {
  id                    String    @id @default(cuid())
  studentId             String
  student               User      @relation(fields: [studentId], references: [id])
  courseId              String
  course                Course    @relation(fields: [courseId], references: [id])
  stripePaymentIntentId String?
  amountPaidUsd         Decimal   @db.Decimal(10, 2)
  instructorPayoutUsd   Decimal   @db.Decimal(10, 2)
  platformFeeUsd        Decimal   @db.Decimal(10, 2)
  zoomJoinUrl           String?
  selectedSessionsJson  String    @default("")
  enrolledAt            DateTime  @default(now())
  instructorPaidOut     Boolean   @default(false)
  instructorPaidOutAt   DateTime?
  feedback              Feedback?
}

model Feedback {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  attended     Boolean
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum Subject {
  BIOLOGY
  PHYSICAL_SCIENCE
  CHEMISTRY
  MATHEMATICS
}

enum CourseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CourseType {
  LIVE
  SELF_PACED
}
